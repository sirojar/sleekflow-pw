    "report": "playwright show-report",
    "codegen": "playwright codegen https://sleekflow.io"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.0",
    "dotenv": "^17.4.1",
    "typescript": "^5.4.0"
  }
}
