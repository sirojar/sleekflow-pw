{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@page-objects/*": ["page-objects/*"],
      "@types-local/*": ["types/*"],
      "@utils/*": ["utils/*"]
    }
  },
  "include": ["page-objects/**/*.ts", "tests/**/*.ts", "utils/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
