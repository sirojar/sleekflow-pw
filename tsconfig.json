{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@page-objects/*": ["automation-test/page-objects/*"],
      "@fixtures/*": ["automation-test/fixtures/*"],
      "@types-local/*": ["automation-test/types/*"]
    }
  },
  "include": ["automation-test/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
